<?php
// Configuración de la base de datos
$servername = "localhost";  // Tu servidor (localhost para desarrollo local)
$username = "root";         // Usuario de MySQL (por defecto: root)
$password = "";             // Contraseña de MySQL (vacía por defecto)
$dbname = "tu_base_datos";  // Nombre de tu base de datos

// Crear conexión
$conexion = new mysqli($servername, $username, $password, $dbname);

// Verificar la conexión
if ($conexion->connect_error) {
    die("Conexión fallida: " . $conexion->connect_error);
}

// Establecer charset UTF-8
$conexion->set_charset("utf8");

// Mensaje de éxito (opcional)
// echo "Conexión exitosa";
?>
